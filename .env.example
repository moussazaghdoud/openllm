# SecureLLM — Environment Variables

# Redis
REDIS_URL=redis://localhost:6379/0

# API Auth
API_SECRET_KEY=change-me-to-a-random-64-char-string
ADMIN_API_KEY=change-me-admin-key

# Presidio (built-in, no external service needed)
# PRESIDIO_EXTERNAL_URL=  # optional: use an external Presidio service instead of built-in

# LLM upstream (the target LLM that SecureLLM proxies to)
# LLM_UPSTREAM_URL=https://api.anthropic.com
# LLM_UPSTREAM_API_KEY=sk-ant-...

# Server
HOST=0.0.0.0
PORT=8000
